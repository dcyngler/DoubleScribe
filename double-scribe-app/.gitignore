# ---------------------------------------------------------------------------
# CONFIDENTIAL — never commit. These hold real transcribed call content.
# ---------------------------------------------------------------------------
transcripts/
index.json
*.txt.bak

# ---------------------------------------------------------------------------
# Python environment & caches
# ---------------------------------------------------------------------------
.venv/
__pycache__/
*.py[cod]
*.egg-info/

# ---------------------------------------------------------------------------
# Build artifacts (regenerated by PyInstaller / Inno Setup)
# ---------------------------------------------------------------------------
build/
dist/
installer/

# ---------------------------------------------------------------------------
# Model weights — too large for git; re-staged at build time.
#   build_assets/whisper-small : Whisper model, copied from the HuggingFace cache
#   models/                    : sherpa diariser ONNX (only the Tkinter apps use it)
# Remove the "models/" line if you want the diariser to work on a fresh clone.
# ---------------------------------------------------------------------------
build_assets/
models/

# ---------------------------------------------------------------------------
# Logs & machine-specific bits
# ---------------------------------------------------------------------------
*.log
*.lnk
smoke.txt

# Claude Code personal/local settings (per-machine, not shared)
.claude/settings.local.json

# ---------------------------------------------------------------------------
# CONFIDENTIAL — never commit. These hold real transcribed call content.
# ---------------------------------------------------------------------------
transcripts/
index.json
settings.json
*.txt.bak

# ---------------------------------------------------------------------------
# Python environment & caches
# ---------------------------------------------------------------------------
.venv/
__pycache__/
*.py[cod]
*.egg-info/

# ---------------------------------------------------------------------------
# Build artifacts (regenerated by PyInstaller / Inno Setup)
# ---------------------------------------------------------------------------
build/
dist/
installer/

# ---------------------------------------------------------------------------
# Model weights — too large for git; re-staged at build time.
#   build_assets/whisper-small : Whisper model, copied from the HuggingFace cache
#   models/                    : sherpa ONNX models -- Tkinter diariser + the new app's
#                                "Them" voice-change split both need nemo_en_titanet_small.onnx
# Remove the "models/" line if you want these features to work on a fresh clone.
# ---------------------------------------------------------------------------
build_assets/
models/

# ---------------------------------------------------------------------------
# Logs & machine-specific bits
# ---------------------------------------------------------------------------
*.log
*.lnk
smoke.txt

# Claude Code personal/local settings (per-machine, not shared)
.claude/settings.local.json

# ---------------------------------------------------------------------------
# Update-signing private key — NEVER commit. Root of trust for the in-app
# auto-updater's signature check (see scripts/generate_update_key.py). Keep a
# backup of this file somewhere safe outside the repo; losing it means you
# can't sign a verifiable update again without shipping a new public key.
# ---------------------------------------------------------------------------
update-signing-key.pem*
